# ---- Backend environment variables --------------------------------------- #
# Copy to .env for local (non-docker) runs. Never commit real secrets.

# SQLAlchemy database URL. For local docker-compose this points at the "db"
# service. Managed providers (Render/Railway) inject their own DATABASE_URL.
DATABASE_URL=postgresql+psycopg2://ims:ims_password@db:5432/ims

# Comma-separated allowed CORS origins, or "*" for all (demo only).
# e.g. CORS_ORIGINS=https://your-frontend.vercel.app
CORS_ORIGINS=*

# Products with stock strictly below this count as "low stock" on the dashboard.
LOW_STOCK_THRESHOLD=10

# Insert demo products/customers on first startup when the DB is empty.
SEED_ON_STARTUP=true

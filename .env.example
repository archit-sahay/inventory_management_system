# ======================================================================== #
#  Root environment for docker-compose. Copy to .env and adjust as needed.
#  NEVER commit the real .env file (it is git-ignored).
# ======================================================================== #

# ---- PostgreSQL ---------------------------------------------------------- #
POSTGRES_USER=ims
POSTGRES_PASSWORD=change_me_in_production
POSTGRES_DB=ims

# ---- Backend ------------------------------------------------------------- #
# Allowed CORS origins (comma-separated) or "*" for any. For a real deploy set
# this to your frontend URL, e.g. https://your-app.vercel.app
CORS_ORIGINS=*
LOW_STOCK_THRESHOLD=10
SEED_ON_STARTUP=true
BACKEND_PORT=8000

# ---- Frontend ------------------------------------------------------------ #
# Backend URL the browser uses. For local docker-compose this is the
# host-published backend port. Baked into the frontend at build time.
VITE_API_URL=http://localhost:8000
FRONTEND_PORT=3000

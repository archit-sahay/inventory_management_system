# Base URL of the backend API.
# - Local dev (vite):           http://localhost:8000
# - Local docker-compose:       http://localhost:8000  (backend published on host)
# - Production (Vercel/Netlify): https://your-backend.onrender.com
#
# Vite inlines VITE_* variables at BUILD time, so this must be set before
# `npm run build` / `docker build`.
VITE_API_URL=http://localhost:8000
